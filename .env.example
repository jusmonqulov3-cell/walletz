# Supabase project URL — Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — same page, "service_role". Server-only, keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret you choose; pass it as ?secret_token=... when setting the webhook so
# only Telegram can call /api/telegram
TELEGRAM_WEBHOOK_SECRET=

# Bot username without the @ (used to build the t.me deep link), public
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Absolute, HTTPS base URL of the deployed app (no trailing slash). Required for
# the Telegram Mini App entry points (menu button + in-message buttons), e.g.
# https://pulnazorat.vercel.app — on Vercel this falls back to the project's
# production domain automatically if unset.
NEXT_PUBLIC_APP_URL=

# Admin panel (/admin) access. Both lists are comma-separated; leave both empty
# to disable admin access entirely (fails closed).
#
# PREFERRED: immutable Supabase user UIDs. UIDs can't be claimed by registering
# an email, so this is takeover-proof. Find a UID in Supabase → Auth → Users.
#   ADMIN_USER_IDS=11111111-2222-3333-4444-555555555555
ADMIN_USER_IDS=
#
# OPTIONAL fallback: emails (case-insensitive). Only honored for CONFIRMED
# emails, so it requires Supabase email confirmation to be enabled. Prefer UIDs.
#   ADMIN_EMAILS=you@example.com, boss@example.com
ADMIN_EMAILS=

# Secret protecting the proactive-notification cron jobs (/api/cron/*). Vercel
# Cron sends it as "Authorization: Bearer <CRON_SECRET>"; you can also trigger a
# job manually with ?secret=... Choose any long random string.
CRON_SECRET=
